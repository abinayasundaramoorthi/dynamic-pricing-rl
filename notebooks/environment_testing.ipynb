   "cell_type": "code",
   "execution_count": 5,
   "id": "eadfba4b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Inventory left: 96 | Days left: 29\n",
      "render() PASSED\n"
     ]
    }
   ],
   "source": [
    "env.render()\n",
    "print(\"render() PASSED\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "4cd1ffdc",
   "metadata": {},
   "source": [
    "## Test 4: Run Multiple Episodes with Random Actions\n",
    "\n",
    "Run several full episodes, choosing random price actions each step, and log observations to confirm the environment runs without runtime errors."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "bfa7c1e3",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Episode 1: finished in 30 steps | Total revenue: 34000.00\n",
      "Episode 2: finished in 29 steps | Total revenue: 33700.00\n",
      "Episode 3: finished in 30 steps | Total revenue: 35800.00\n",
      "Episode 4: finished in 25 steps | Total revenue: 30000.00\n",
      "Episode 5: finished in 30 steps | Total revenue: 29200.00\n",
      "\n",
      "All episodes completed with no runtime errors.\n"
     ]
    }
   ],
   "source": [
    "import random\n",
    "\n",
    "NUM_EPISODES = 5\n",
    "log = []\n",
    "\n",
    "for episode in range(1, NUM_EPISODES + 1):\n",
    "    state = env.reset()\n",
    "    done = False\n",
    "    total_reward = 0\n",
    "    steps = 0\n",
    "\n",
    "    while not done:\n",
    "        action = random.randint(0, len(env.price_levels) - 1)\n",
    "        next_state, reward, done, info = env.step(action)\n",
    "\n",
    "        log.append({\n",
    "            \"episode\": episode,\n",
    "            \"step\": steps,\n",
    "            \"price\": info[\"price\"],\n",
    "            \"units_sold\": info[\"units_sold\"],\n",
    "            \"inventory_left\": next_state[0],\n",
    "            \"days_left\": next_state[1],\n",
    "            \"reward\": reward\n",
    "        })\n",
    "\n",
    "        total_reward += reward\n",
    "        steps += 1\n",
    "\n",
    "    print(f\"Episode {episode}: finished in {steps} steps | Total revenue: {total_reward:.2f}\")\n",
    "\n",
    "print(\"\\nAll episodes completed with no runtime errors.\")"
   ]
  },
